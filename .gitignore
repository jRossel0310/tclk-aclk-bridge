# Python venv
.venv/
__pycache__/
*.pyc

# Simulation build artifacts & waveforms
sim_build/
*.fst
*.fst.hier
*.vcd
results.xml

# Vivado build artifacts (the bitstream flow). Source stays tracked
# (build*.tcl, uart_echo_bd.tcl); generated outputs are ignored.
# /build/ is the repo-local default (./build/kria/<name>); build-manifest.json
# lives under it and is intentionally ignored (it is a build output).
/build/
vivado/build/
vivado/*.log
vivado/*.jou
.Xil/
*.str

# Stray GUI-created Vivado projects (use the scripted vivado/ flow instead).
project_1/
*.xpr

# Compiled/loadable deploy artifacts — the deploy/ SOURCES (.dts/.bif/.json/.py)
# ARE tracked; these generated outputs are not.
*.dtbo
*.bit.bin
*.bit

# GT Wizard IP generated synthesis XML (large); keep .xci + .veo
vivado/ip/**/*.xml
vivado/ip/*.log
vivado/ip/*.jou
vivado_*.backup.jou
vivado_*.backup.log
vivado/ip/aclkgt_gt/aclkgt_gt.bmj
vivado/ip/aclkgt_gt/aclkgt_gt.vho
vivado/ip/aclkgt_gt/aclkgt_gt_bmstub.v
vivado/ip/aclkgt_gt/hdl/
vivado/ip/aclkgt_gt/synth/

# Superpowers SDD scratch (task briefs, reports, progress ledger): on-disk only, not part of the repo
.superpowers/

# --- repo cleanup (2026-07-01) ---
# Root-level Vivado logs (vivado/*.log covers the subdir; these are repo-root)
/vivado.jou
/vivado.log
# Stray GUI GT-configuration Vivado project (use the scripted vivado/ip flow)
gt_configuration/
# Evan's raw starter-code reference dump: duplicate module names vs rtl/aclk_bridge,
# kept on disk but out of git to avoid a duplicate-module hazard.
rtl/Li_Files/
# GT IP generated products (regenerated from the tracked aclkgt_gt.xci)
vivado/ip/_ref_*.veo.ports
vivado/ip/aclkgt_gt/*.dcp
vivado/ip/aclkgt_gt/*_sim_netlist.*
vivado/ip/aclkgt_gt/*_stub.*
vivado/ip/aclkgt_gt/doc/
vivado/ip/aclkgt_gt/sim/
vivado/ip/aclkgt_gt_[0-9]*/
# Generated HTML render of the hardware-interface guide (keep the .md + .pdf)
docs/generated/*.html

# VS Code: ignore personal editor config, keep the shared task/extension files
.vscode/*
!.vscode/tasks.json
!.vscode/extensions.json
