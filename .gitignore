# Python venv
.venv/
__pycache__/
*.pyc

# Simulation build artifacts & waveforms
sim_build/
*.fst
*.fst.hier
*.vcd
results.xml

# Vivado build artifacts (the bitstream flow). Keep build.tcl + uart_echo_bd.tcl;
